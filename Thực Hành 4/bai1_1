<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Quản lý điểm sinh viên</title>

    <style>
        body {
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            margin-bottom: 10px;
        }

        .form-box {
            margin-bottom: 15px;
        }

        input {
            padding: 6px;
            margin-right: 8px;
        }

        button {
            padding: 6px 12px;
            cursor: pointer;
        }

        table {
            border-collapse: collapse;
            width: 600px;
        }

        th,
        td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }

        th {
            background: #eee;
        }

        .bad {
            background: yellow;
        }

        .summary {
            margin-top: 15px;
            font-weight: bold;
        }
    </style>

</head>

<body>

    <h2>Quản Lý Điểm Sinh Viên</h2>

    <div class="form-box">

        <input id="studentName" type="text" placeholder="Nhập họ tên">

        <input id="studentScore" type="number" placeholder="Điểm (0-10)">

        <button id="btnAdd">Thêm</button>

    </div>


    <table>

        <thead>
            <tr>
                <th>STT</th>
                <th>Họ tên</th>
                <th>Điểm</th>
                <th>Xếp loại</th>
                <th>Xóa</th>
            </tr>
        </thead>

        <tbody id="studentTable"></tbody>

    </table>


    <div class="summary" id="resultBox"></div>


    <script>

        let listStudent = []

        const nameInput = document.getElementById("studentName")
        const scoreInput = document.getElementById("studentScore")

        const table = document.getElementById("studentTable")
        const resultBox = document.getElementById("resultBox")


        function rank(score) {

            if (score >= 8.5) return "Giỏi"

            if (score >= 7) return "Khá"

            if (score >= 5) return "Trung bình"

            return "Yếu"

        }


        function render() {

            table.innerHTML = ""

            listStudent.forEach((sv, index) => {

                let tr = document.createElement("tr")

                if (sv.score < 5) {
                    tr.classList.add("bad")
                }

                tr.innerHTML = `

<td>${index + 1}</td>
<td>${sv.name}</td>
<td>${sv.score}</td>
<td>${rank(sv.score)}</td>
<td>
<button data-id="${index}" class="btnDelete">Xóa</button>
</td>

`

                table.appendChild(tr)

            })

            updateSummary()

        }


        function updateSummary() {

            let total = listStudent.length

            let avg = 0

            if (total > 0) {

                let sum = listStudent.reduce((s, sv) => s + sv.score, 0)

                avg = (sum / total).toFixed(2)

            }

            resultBox.textContent =
                `Tổng sinh viên: ${total} | Điểm trung bình: ${avg}`

        }


        function addStudent() {

            let name = nameInput.value.trim()

            let score = parseFloat(scoreInput.value)

            if (name === "") {
                alert("Vui lòng nhập họ tên")
                return
            }

            if (isNaN(score) || score < 0 || score > 10) {
                alert("Điểm phải từ 0 đến 10")
                return
            }

            listStudent.push({
                name: name,
                score: score
            })

            render()

            nameInput.value = ""
            scoreInput.value = ""

            nameInput.focus()

        }


        document.getElementById("btnAdd")
            .addEventListener("click", addStudent)


        scoreInput.addEventListener("keypress", e => {

            if (e.key === "Enter") {
                addStudent()
            }

        })


        table.addEventListener("click", e => {

            if (e.target.classList.contains("btnDelete")) {

                let id = e.target.dataset.id

                listStudent.splice(id, 1)

                render()

            }

        })

    </script>

</body>

</html>
