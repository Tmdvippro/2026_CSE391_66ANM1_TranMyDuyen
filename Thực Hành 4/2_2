<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Form đặt hàng</title>

    <style>
        body {
            font-family: Arial;
            background: #f4f6f9;
            display: flex;
            justify-content: center;
            padding: 30px;
        }

        .container {
            width: 520px;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h2 {
            text-align: center;
        }

        .field {
            margin-top: 12px;
        }

        label {
            font-weight: bold;
        }

        input,
        select,
        textarea {
            width: 100%;
            padding: 8px;
            margin-top: 4px;
        }

        textarea {
            min-height: 80px;
        }

        .error {
            color: red;
            font-size: 13px;
        }

        .counter {
            text-align: right;
            font-size: 12px;
            color: #666;
        }

        .row {
            display: flex;
            gap: 10px;
            margin-top: 5px;
        }

        .total {
            font-weight: bold;
            margin-top: 10px;
        }

        button {
            width: 100%;
            padding: 10px;
            margin-top: 12px;
            background: #2d8cff;
            border: none;
            color: white;
        }

        #confirmBox,
        #success {
            display: none;
            margin-top: 15px;
            border: 1px solid #ccc;
            padding: 10px;
        }

        .actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .red {
            color: red;
        }
    </style>

</head>

<body>

    <div class="container">

        <h2>Đặt hàng</h2>

        <form id="orderForm">

            <div class="field">

                <label>Sản phẩm</label>

                <select id="product">
                    <option value="">-- Chọn sản phẩm --</option>
                    <option value="Áo">Áo</option>
                    <option value="Quần">Quần</option>
                    <option value="Giày">Giày</option>
                </select>

                <div class="error" id="productError"></div>

            </div>


            <div class="field">

                <label>Số lượng</label>

                <input type="number" id="quantity">

                <div class="error" id="quantityError"></div>

            </div>


            <div class="field">

                <label>Ngày giao</label>

                <input type="date" id="date">

                <div class="error" id="dateError"></div>

            </div>


            <div class="field">

                <label>Địa chỉ</label>

                <input type="text" id="address">

                <div class="error" id="addressError"></div>

            </div>


            <div class="field">

                <label>Ghi chú</label>

                <textarea id="note"></textarea>

                <div class="counter" id="noteCount">0/200</div>

                <div class="error" id="noteError"></div>

            </div>


            <div class="field">

                <label>Thanh toán</label>

                <div class="row">
                    <label><input type="radio" name="payment" value="COD"> COD</label>
                    <label><input type="radio" name="payment" value="Bank"> Chuyển khoản</label>
                    <label><input type="radio" name="payment" value="Wallet"> Ví điện tử</label>
                </div>

                <div class="error" id="paymentError"></div>

            </div>


            <div class="total" id="totalMoney">
                Tổng tiền: 0 đ
            </div>

            <button type="submit">Đặt hàng</button>

        </form>


        <div id="confirmBox">

            <div id="summary"></div>

            <div class="actions">

                <button type="button" id="confirmBtn">Xác nhận</button>
                <button type="button" id="cancelBtn">Hủy</button>

            </div>

        </div>


        <div id="success"></div>

    </div>


    <script>

        const form = document.getElementById("orderForm")

        const product = document.getElementById("product")
        const quantity = document.getElementById("quantity")
        const date = document.getElementById("date")
        const address = document.getElementById("address")
        const note = document.getElementById("note")

        const noteCount = document.getElementById("noteCount")
        const totalMoney = document.getElementById("totalMoney")

        const confirmBox = document.getElementById("confirmBox")
        const summary = document.getElementById("summary")

        const confirmBtn = document.getElementById("confirmBtn")
        const cancelBtn = document.getElementById("cancelBtn")

        const success = document.getElementById("success")


        const price = {
            "Áo": 150000,
            "Quần": 200000,
            "Giày": 500000
        }


        function showError(id, msg) {
            document.getElementById(id + "Error").innerText = msg
        }

        function clearError(id) {
            document.getElementById(id + "Error").innerText = ""
        }

        function formatMoney(n) {
            return Number(n).toLocaleString("vi-VN") + " đ"
        }


        function calcTotal() {

            let p = product.value
            let q = Number(quantity.value)

            if (!price[p] || !Number.isInteger(q) || q < 1 || q > 99) return 0

            return price[p] * q

        }

        function updateTotal() {
            totalMoney.innerText = "Tổng tiền: " + formatMoney(calcTotal())
        }


        function validateProduct() {

            if (product.value === "") {
                showError("product", "Vui lòng chọn sản phẩm")
                return false
            }

            clearError("product")
            return true

        }


        function validateQuantity() {

            let q = Number(quantity.value)

            if (quantity.value === "") {
                showError("quantity", "Nhập số lượng")
                return false
            }

            if (!Number.isInteger(q) || q < 1 || q > 99) {
                showError("quantity", "Số lượng 1 - 99")
                return false
            }

            clearError("quantity")
            return true

        }


        function validateDate() {

            let v = date.value

            if (v === "") {
                showError("date", "Chọn ngày giao")
                return false
            }

            let today = new Date()

            let min = new Date(today.getFullYear(), today.getMonth(), today.getDate())

            let max = new Date(min)
            max.setDate(max.getDate() + 30)

            let chosen = new Date(v)
            chosen.setHours(0, 0, 0, 0)

            if (chosen < min) {
                showError("date", "Không chọn ngày quá khứ")
                return false
            }

            if (chosen > max) {
                showError("date", "Không quá 30 ngày")
                return false
            }

            clearError("date")
            return true

        }


        function validateAddress() {

            let v = address.value.trim()

            if (v === "" || v.length < 10) {
                showError("address", "Địa chỉ ≥ 10 ký tự")
                return false
            }

            clearError("address")
            return true

        }


        function validateNote() {

            if (note.value.length > 200) {
                showError("note", "Tối đa 200 ký tự")
                return false
            }

            clearError("note")
            return true

        }


        function validatePayment() {

            let checked = document.querySelector('input[name="payment"]:checked')

            if (!checked) {
                showError("payment", "Chọn phương thức thanh toán")
                return false
            }

            clearError("payment")
            return true

        }


        function updateNoteCount() {

            let len = note.value.length

            noteCount.innerText = len + "/200"

            if (len > 200) {
                noteCount.classList.add("red")
            } else {
                noteCount.classList.remove("red")
            }

        }


        function showConfirm() {

            summary.innerHTML = `
<b>Thông tin đơn hàng</b><br>
Sản phẩm: ${product.value}<br>
Số lượng: ${quantity.value}<br>
Tổng tiền: ${formatMoney(calcTotal())}<br>
Ngày giao: ${date.value}<br><br>
<b>Xác nhận đặt hàng?</b>
`

            confirmBox.style.display = "block"

        }


        form.addEventListener("submit", function (e) {

            e.preventDefault()

            let ok =
                validateProduct() &
                validateQuantity() &
                validateDate() &
                validateAddress() &
                validateNote() &
                validatePayment()

            if (ok) {
                showConfirm()
            } else {
                confirmBox.style.display = "none"
            }

        })


        confirmBtn.onclick = function () {

            form.style.display = "none"
            confirmBox.style.display = "none"

            success.style.display = "block"

            success.innerHTML = "Đặt hàng thành công 🎉"

        }


        cancelBtn.onclick = function () {
            confirmBox.style.display = "none"
        }


        product.addEventListener("blur", validateProduct)
        quantity.addEventListener("blur", validateQuantity)
        date.addEventListener("blur", validateDate)
        address.addEventListener("blur", validateAddress)
        note.addEventListener("blur", validateNote)


        product.addEventListener("change", () => {
            clearError("product")
            updateTotal()
        })

        quantity.addEventListener("input", () => {
            clearError("quantity")
            updateTotal()
        })

        date.addEventListener("input", () => clearError("date"))
        address.addEventListener("input", () => clearError("address"))
        note.addEventListener("input", updateNoteCount)

        document.querySelectorAll('input[name="payment"]').forEach(item => {
            item.addEventListener("blur", validatePayment)
            item.addEventListener("change", () => clearError("payment"))
        })


        updateTotal()
        updateNoteCount()

    </script>

</body>

</html>
